# Copy this file to .env or inject these values with your deployment secret manager.
#
# Never commit real private keys, Deepgram keys, or encryption keys.

POSTGRES_DB=interviewloop
POSTGRES_USER=interviewloop
POSTGRES_PASSWORD=change-me

APP_ENV=production
CORS_ORIGINS=https://your-domain.example
AUTO_CREATE_TABLES=false
DATABASE_URL=postgresql+psycopg://interviewloop:change-me@postgres:5432/interviewloop
REDIS_URL=redis://redis:6379/0
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen2.5:7b

DEEPGRAM_API_KEY=

# Required for production email delivery: OTP verification, password reset, and report-ready notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=InterviewLoop
SMTP_USE_TLS=true

JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
REPORT_SIGNATURE_PRIVATE_KEY=
REPORT_SIGNATURE_PUBLIC_KEY=
TOTP_SECRET_ENCRYPTION_KEY=

FLOWER_BASIC_AUTH=admin:change-me
